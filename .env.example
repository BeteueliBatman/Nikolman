# Use the "Nikolman" Supabase project (website), NOT "Nikolman-manage" (CRM).

# Public — safe for the browser (RLS protects the database)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Optional — only for local seed script and future admin tooling (not required on Vercel)
# Supabase → Nikolman project → Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional: comma-separated admin emails allowed to access /admin (not enforced yet)
ADMIN_EMAILS=admin@example.com
