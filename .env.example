# Use the "Nikolman" Supabase project (website), NOT "Nikolman-manage" (CRM).

# Public — safe for the browser (RLS protects the database)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Canonical site URL for sitemap, hreflang, and API origin checks.
# On Vercel Production set this to your real domain (e.g. https://nikolman.ge).
NEXT_PUBLIC_SITE_URL=https://nikolman.vercel.app

# Optional — only for local seed script (not required on Vercel)
# Supabase → Nikolman project → Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional hardening: comma-separated admin emails allowed to access /admin.
# Leave empty to rely only on DB roles in website_admin_profiles.
ADMIN_EMAILS=
